#!/usr/bin/env bash
# Thin wrapper so users can run `mindmap` (or `!mindmap` inside Claude Code)
# to render the cached mindmap with zero model involvement.
#
# Flags:
#   --refresh   Force a full cache refresh before rendering.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)"

if [ "${1:-}" = "--refresh" ] || [ "${1:-}" = "-r" ]; then
  CLAUDE_WORKTREE_FORCE=1 bash "$REPO_ROOT/bin/refresh.sh" >/dev/null
fi

exec python3 "$REPO_ROOT/bin/render.py"
